# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram numeric user ID (use @userinfobot to find it)
ADMIN_USER_ID=123456789

# ── Stripe Payment Links ───────────────────────────────────────────────────────
# Create Payment Links in Stripe Dashboard → Payment Links → + New
# Recommended: set Metadata key "pack_id" = pack_a / pack_b / pack_c
# on each Payment Link so the webhook can map payments to packs.
STRIPE_LINK_PACK_A=https://buy.stripe.com/xxxxxxxxxxxx_pack_a
STRIPE_LINK_PACK_B=https://buy.stripe.com/xxxxxxxxxxxx_pack_b
STRIPE_LINK_PACK_C=https://buy.stripe.com/xxxxxxxxxxxx_pack_c

# Stripe webhook signing secret (Stripe Dashboard → Webhooks → your endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Delivery Links ────────────────────────────────────────────────────────────
# Private Telegram channel invite link OR a protected download URL per pack
DELIVERY_LINK_PACK_A=https://t.me/+xxxxxxxxxxxx
DELIVERY_LINK_PACK_B=https://t.me/+xxxxxxxxxxxx
DELIVERY_LINK_PACK_C=https://t.me/+xxxxxxxxxxxx

# ── Sample Images ─────────────────────────────────────────────────────────────
# Comma-separated Telegram file_ids OR public image URLs (up to 3 per pack)
# To get a file_id: send the image to your bot and check the update payload.
SAMPLE_IMAGES_PACK_A=https://example.com/sample_a1.jpg,https://example.com/sample_a2.jpg
SAMPLE_IMAGES_PACK_B=https://example.com/sample_b1.jpg,https://example.com/sample_b2.jpg
SAMPLE_IMAGES_PACK_C=https://example.com/sample_c1.jpg,https://example.com/sample_c2.jpg

# ── Persona ───────────────────────────────────────────────────────────────────
PERSONA_NAME=Luna
PERSONA_TAGLINE=Your exclusive AI content creator ✨

# ── OpenAI / LLM (optional — bot works without it, uses static copy) ─────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────────────────────
# Replit sets PORT automatically; override locally if needed
PORT=8080
