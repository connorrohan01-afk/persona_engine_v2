entrypoint = "main.py"

# Run button in the editor shell
run = "bash run.sh"

[env]
PORT = "5000"

# Port 5000 is the single public HTTP port — webhook endpoints + health check.
# Telegram bot polling uses outbound connections only — no inbound port needed.
[[ports]]
localPort = 5000
externalPort = 80

[deployment]
# Autoscale deployment on Replit Cloud Run
deploymentTarget = "cloudrun"
run = ["sh", "-c", "bash run.sh"]
