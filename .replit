entrypoint = "main.py"

# "Run" button in the editor shell — same command as the deployment.
# Do not run this manually if a deployment is already active.
run = "python3.11 main.py"

[env]
PORT = "5000"

# Expose port 5000 as the public HTTP port (webhook endpoints).
# Telegram bot polling uses outbound connections only — no inbound port needed.
[[ports]]
localPort = 5000
externalPort = 80

[deployment]
# Deployment target — autoscaled Cloud Run container on Replit.
deploymentTarget = "cloudrun"
run = ["sh", "-c", "python3.11 main.py"]
